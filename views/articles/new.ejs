<%- include('../partials/header') %>

<form id="new-article-form" action="/articles" method="POST">
    <div class="form-grp">
        <label for="title">Title</label>
        <input type="text" name="title" id="title" required>
    </div>
    <div class="form-grp">
        <label for="source"> Source (URL)</label>
        <input type="text" name="source" id="source" required>
    </div>
    <div class="form-grp">
        <label for="category">Category</label>
        <select name="category" id="title" selected required>
            <option value="">
                -- Select a Category
            </option>
            <% validCategories.forEach((category) => { %>
                <option value="<%= category %>">
                    <%= category %>
                </option>
                <% }) %>
        </select>
    </div>
    <div class="form-grp">
        <label for="public">Share this article publicly?</label>
        <input name="public" type="checkbox">
    </div>
    <div class="form-grp">
        <label for="content">Content</label>
        <textarea id="content" name="content" rows="10" cols="40" required></textarea>
    </div>
    <input type="submit" value="Add Article">
</form>

<%- include('../partials/footer') %>